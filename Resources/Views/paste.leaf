<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>New Paste — Stephen Parkinson</title>
        <link rel="stylesheet" href="/css/style.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
    </head>
    <body>
        <nav>
            <a href="/">Home</a>
            <a href="/resume">Resume</a>
            <a href="/paste">Paste</a>
        </nav>

        <h1>New Paste</h1>

        <section>
            <div id="error" class="error"></div>

            <label for="title">Title</label>
            <div class="hint">Optional title for your paste.</div>
            <input type="text" id="title" placeholder="Untitled" maxlength="200" />

            <label for="content">Content <span class="required">*</span></label>
            <div class="hint">Required. Maximum 1 MB.</div>
            <div class="editor-wrapper">
                <pre aria-hidden="true"><code id="preview-code" class="hljs"></code></pre>
                <textarea id="content" placeholder="Paste your content here..." spellcheck="false"></textarea>
            </div>

            <div class="row">
                <div>
                    <label for="language">Language</label>
                    <select id="language">
                        <option value="plaintext">Plain Text</option>
                        <option value="bash">Bash</option>
                        <option value="c">C</option>
                        <option value="cpp">C++</option>
                        <option value="css">CSS</option>
                        <option value="dockerfile">Dockerfile</option>
                        <option value="go">Go</option>
                        <option value="html">HTML</option>
                        <option value="java">Java</option>
                        <option value="javascript">JavaScript</option>
                        <option value="json">JSON</option>
                        <option value="kotlin">Kotlin</option>
                        <option value="markdown">Markdown</option>
                        <option value="python">Python</option>
                        <option value="ruby">Ruby</option>
                        <option value="rust">Rust</option>
                        <option value="sql">SQL</option>
                        <option value="swift">Swift</option>
                        <option value="typescript">TypeScript</option>
                        <option value="yaml">YAML</option>
                    </select>
                </div>
                <div>
                    <label for="password">Password</label>
                    <input type="password" id="password" placeholder="Leave blank for no password" />
                </div>
            </div>

            <label class="expiry-label">
                Expires: <span class="expiry-value" id="expiry-display">5 minutes</span>
            </label>
            <input type="range" id="expiry" min="1" max="10" value="5"
                   oninput="document.getElementById('expiry-display').textContent = this.value + ' minute' + (this.value == 1 ? '' : 's')" />

            <button id="submit-btn" onclick="submitPaste()">Create Paste</button>
        </section>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
        <script>
            const contentEl = document.getElementById('content');
            const codeEl = document.getElementById('preview-code');
            const langEl = document.getElementById('language');

            function updatePreview() {
                codeEl.removeAttribute('data-highlighted');
                codeEl.className = 'hljs language-' + langEl.value;
                // Trailing newline keeps the highlight layer tall enough for the caret on the last line.
                codeEl.textContent = contentEl.value + '\n';
                hljs.highlightElement(codeEl);
            }

            contentEl.addEventListener('input', updatePreview);
            langEl.addEventListener('change', updatePreview);
            updatePreview();

            async function submitPaste() {
                const content = contentEl.value;
                if (!content.trim()) {
                    showError('Content is required.');
                    return;
                }

                const btn = document.getElementById('submit-btn');
                btn.disabled = true;
                btn.textContent = 'Creating…';
                hideError();

                try {
                    const res = await fetch('/api/paste', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            title: document.getElementById('title').value.trim(),
                            content,
                            language: langEl.value,
                            expiry: parseInt(document.getElementById('expiry').value),
                            password: document.getElementById('password').value || undefined,
                        }),
                    });
                    const data = await res.json();
                    if (!res.ok) {
                        showError(data.error || 'Failed to create paste.');
                        return;
                    }
                    sessionStorage.setItem('pastePassword_' + data.id, document.getElementById('password').value || '');
                    window.location.href = data.url;
                } catch {
                    showError('Network error. Please try again.');
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Create Paste';
                }
            }

            function showError(msg) {
                const el = document.getElementById('error');
                el.textContent = msg;
                el.style.display = 'block';
            }
            function hideError() {
                document.getElementById('error').style.display = 'none';
            }
        </script>
    </body>
</html>
