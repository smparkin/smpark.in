<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Paste — Stephen Parkinson</title>
        <link rel="stylesheet" href="/css/style.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
    </head>
    <body>
        <nav>
            <a href="/">Home</a>
            <a href="/resume">Resume</a>
            <a href="/paste">Paste</a>
        </nav>

        <div id="loading">Loading…</div>
        <div id="app" style="display:none"></div>

        <script>
            const pasteID = '#(pasteID)';

            function fmt(iso) {
                return new Date(iso).toLocaleString();
            }

            function renderMeta(paste) {
                return `
                    <section>
                        <div class="meta-grid">
                            <div class="meta-item">
                                <div class="key">Language</div>
                                <div class="val">${esc(paste.language || 'Plain Text')}</div>
                            </div>
                            <div class="meta-item">
                                <div class="key">Created</div>
                                <div class="val">${fmt(paste.created_at)}</div>
                            </div>
                            <div class="meta-item">
                                <div class="key">Expires</div>
                                <div class="val">${paste.expires_at ? fmt(paste.expires_at) : 'Never'}</div>
                            </div>
                        </div>
                    </section>
                    <section>
                        <pre><code class="language-${esc(paste.language || 'plaintext')}">${esc(paste.content)}</code></pre>
                    </section>`;
            }

            function renderHeader(paste) {
                const rawLink = paste.protected ? '' : `<a class="btn" href="/api/paste/${pasteID}/raw" target="_blank">Raw</a>`;
                return `
                    <div class="page-title">
                        <h1>${esc(paste.title || 'Untitled')}</h1>
                        <div class="actions">
                            <button onclick="copyLink()">Copy Link</button>
                            <button onclick="copyText()">Copy Text</button>
                            ${rawLink}
                        </div>
                    </div>`;
            }

            function renderLocked() {
                return `
                    <div class="page-title"><h1>Password Required</h1></div>
                    <section>
                        <div id="pw-error" class="alert alert-error" style="display:none"></div>
                        <label for="pw-input">Password</label>
                        <div class="hint">This paste is password-protected.</div>
                        <input type="password" id="pw-input" placeholder="Enter password"
                            onkeydown="if(event.key==='Enter') unlock()" />
                        <button class="unlock-btn" id="unlock-btn" onclick="unlock()">Unlock</button>
                    </section>`;
            }

            function renderNotFound() {
                return `
                    <div class="page-title"><h1>Not Found</h1></div>
                    <section>
                        <div class="alert alert-error">This paste does not exist.</div>
                        <a href="/paste">Create a new paste →</a>
                    </section>`;
            }

            function renderExpired() {
                return `
                    <div class="page-title"><h1>Expired</h1></div>
                    <section>
                        <div class="alert alert-warn">This paste has expired and is no longer available.</div>
                        <a href="/paste">Create a new paste →</a>
                    </section>`;
            }

            function renderError() {
                return `
                    <div class="page-title"><h1>Error</h1></div>
                    <section>
                        <div class="alert alert-error">Failed to load paste. Please try again.</div>
                    </section>`;
            }

            function esc(str) {
                return String(str)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
            }

            let currentPaste = null;

            function show(html) {
                document.getElementById('loading').style.display = 'none';
                const app = document.getElementById('app');
                app.style.display = 'block';
                app.innerHTML = html;
                app.querySelectorAll('pre code').forEach(el => hljs.highlightElement(el));
            }

            async function load(password) {
                const headers = {};
                if (password) headers['X-Paste-Password'] = password;
                try {
                    const res = await fetch(`/api/paste/${pasteID}`, { headers });
                    if (res.status === 404) { show(renderNotFound()); return; }
                    if (res.status === 410) { show(renderExpired()); return; }
                    if (res.status === 403) { show(renderLocked()); return; }
                    if (!res.ok) { show(renderError()); return; }
                    const paste = await res.json();
                    currentPaste = paste;
                    document.title = (paste.title || 'Untitled') + ' — Paste';
                    show(renderHeader(paste) + renderMeta(paste));
                } catch {
                    show(renderError());
                }
            }

            async function unlock() {
                const pw = document.getElementById('pw-input').value;
                if (!pw) return;
                const btn = document.getElementById('unlock-btn');
                btn.disabled = true;
                btn.textContent = 'Unlocking…';
                document.getElementById('pw-error').style.display = 'none';
                try {
                    const res = await fetch(`/api/paste/${pasteID}`, {
                        headers: { 'X-Paste-Password': pw }
                    });
                    if (res.status === 403) {
                        const el = document.getElementById('pw-error');
                        el.textContent = 'Incorrect password.';
                        el.style.display = 'block';
                        btn.disabled = false;
                        btn.textContent = 'Unlock';
                        return;
                    }
                    if (res.status === 404) { show(renderNotFound()); return; }
                    if (res.status === 410) { show(renderExpired()); return; }
                    if (!res.ok) { show(renderError()); return; }
                    const paste = await res.json();
                    currentPaste = paste;
                    document.title = (paste.title || 'Untitled') + ' — Paste';
                    show(renderHeader(paste) + renderMeta(paste));
                } catch {
                    show(renderError());
                }
            }

            function copyText() {
                if (!currentPaste) return;
                navigator.clipboard.writeText(currentPaste.content).then(() => {
                    const btns = document.querySelectorAll('.actions button');
                    btns.forEach(b => { if (b.textContent === 'Copy Text') { b.textContent = 'Copied!'; setTimeout(() => b.textContent = 'Copy Text', 2000); } });
                });
            }

            function copyLink() {
                navigator.clipboard.writeText(window.location.href).then(() => {
                    const btns = document.querySelectorAll('.actions button');
                    btns.forEach(b => { if (b.textContent === 'Copy Link') { b.textContent = 'Copied!'; setTimeout(() => b.textContent = 'Copy Link', 2000); } });
                });
            }

            const savedPw = sessionStorage.getItem('pastePassword_' + pasteID) || '';
            load(savedPw);
        </script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    </body>
</html>
